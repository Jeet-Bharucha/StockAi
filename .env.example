# ── Required ──────────────────────────────────────────────────────────────────
# Finnhub API key — free at https://finnhub.io/dashboard
FINNHUB_KEY=your_finnhub_api_key

# MongoDB Atlas connection string — free at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/stockai?retryWrites=true&w=majority

# JWT secret — any long random string (openssl rand -hex 32)
JWT_SECRET=your_long_random_secret_here

# ── AI Analysis (optional) ────────────────────────────────────────────────────
# Anthropic Claude API — https://console.anthropic.com
# Enables AI-powered natural language analysis in the dashboard
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Automated Email/SMS Alerts (optional) ─────────────────────────────────────
# Gmail address to send alerts FROM
ALERT_GMAIL_USER=your.gmail@gmail.com
# Gmail App Password — myaccount.google.com/apppasswords
ALERT_GMAIL_PASS=xxxx xxxx xxxx xxxx
# Where to receive alerts (comma-separated for email + SMS gateway)
ALERT_EMAIL_TO=your@email.com

# ── Private Mode (optional) ───────────────────────────────────────────────────
# Adds HTTP Basic Auth popup before any page loads
SITE_PASSWORD=your_site_password
# Restricts registration and login to one email address
ALLOWED_EMAIL=your@email.com
